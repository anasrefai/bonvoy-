rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /products/{id} {
      allow read: if resource.data.available == true || request.auth != null;
      allow write: if false;
      match /extras/{extraId} {
        allow read: if true;
        allow write: if false;
      }
    }

    match /extraGroups/{groupId} {
      allow read: if true;
      allow write: if false;
      match /extras/{extraId} {
        allow read: if true;
        allow write: if false;
      }
    }

    match /orders/{id} {
      // Authenticated admins can read for onSnapshot real-time updates.
      // Writes only via Admin SDK through Netlify Functions.
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /settings/{doc} {
      // Public read needed for store closed banner and delivery fees on customer site.
      allow read: if true;
      allow write: if false;
    }

    match /rate_limits/{id} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
